DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Required if MySQL user has a password (copy to .env in this folder)
DB_PASSWORD=your_mysql_password
DB_NAME=excelcusor
# Set to false in production and use migrations instead
DB_SYNCHRONIZE=true

# Nest HTTP port (default). Frontend: same host/port in NEXT_PUBLIC_NEST_API_URL (see Excel-Frontend/env.example).
PORT=3005

# Optional: deployed frontends only (comma-separated). Localhost / 127.0.0.1:any port is always allowed for dev.
# CORS_ORIGINS=https://your-app.vercel.app

# JWT (required in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Super admin (optional): if both are set, the server creates this user on startup when missing.
# Also used so signup with this username gets role super_admin only when the password matches.
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=
